{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monitor Browser",
  "version": "1.0.0",
  "identifier": "com.osint.monitor-browser",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Monitor Browser",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data: https: http:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost https://osint-worldview.vercel.app https://dns.google http://ip-api.com https: http:; frame-src 'self' asset: https://asset.localhost; object-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 OSINT Worldview",
    "shortDescription": "Browser for intelligence analysts",
    "longDescription": "Monitor Browser is a standalone OSINT intelligence browser where the new-tab/homepage IS the OSINTworldview geopolitical dashboard."
  },
  "plugins": {
    "http": {
      "scope": {
        "allow": [
          { "url": "https://osint-worldview.vercel.app/*" },
          { "url": "https://dns.google/*" },
          { "url": "http://ip-api.com/*" },
          { "url": "https://*/*" },
          { "url": "http://*/*" }
        ]
      }
    },
    "shell": {
      "open": true
    }
  }
}
